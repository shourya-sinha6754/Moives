<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Dashboard</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background: #1e272e;
            color: white;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
        }

        .box {
            text-align: center;
            background: #2f3640;
            padding: 40px;
            border-radius: 10px;
            box-shadow: 0 0 20px rgba(0,0,0,0.5);
        }

        a {
            display: inline-block;
            margin-top: 20px;
            padding: 10px 20px;
            background: #00a8ff;
            color: white;
            text-decoration: none;
            border-radius: 5px;
        }

        a:hover {
            background: #0097e6;
        }
    </style>
</head>
<body>

<div class="box">
    <h1>Welcome 🎉</h1>
    <p>You have successfully logged in.</p>
    <a href="login.html">Logout</a>
</div>

</body>
</html>
